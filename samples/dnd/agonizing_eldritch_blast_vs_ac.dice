# Compare several 11th-level eldritch blast packages across armor classes.

import "std:dnd/spells.dice"

plain = ~eldritch_blast_by_level(11, [AC:10:22], 7)
agonizing = ~agonizing_eldritch_blast_by_level(11, [AC:10:22], 7, 4)
hexed = ~hex_eldritch_blast_action(3, [AC:10:22], 7, 4)

render(plain, "Plain", agonizing, "Agonizing", hexed, "Hex + Agonizing", "Armor class", "11th-level eldritch blast vs AC")
